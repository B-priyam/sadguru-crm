generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String            @id @default(uuid())
  name            String
  email           String            @unique
  password        String
  createdAt       DateTime          @default(now())
  clients         Client[]
  properties      Property[]
  relentlyDeleted RecentlyDeleted[]
}

model Client {
  id                 String    @id @default(uuid())
  clientName         String
  budget             String?
  createdAt          DateTime  @default(now())
  income             String?
  interestedProperty String?
  location           String?
  number             String
  occupation         String?
  propertyType       String?
  residence          String?
  stage              String
  updatedAt          DateTime?
  visit              DateTime?
  alternateNumber    String[]
  followUp           Json?
  notes              Json?
  propertyArea       String?
  userId             String
  user               User?     @relation(fields: [userId], references: [id])
}

model Property {
  id        String   @id @default(uuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  units     Json
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

model RecentlyDeleted {
  id                 String    @id @default(uuid())
  clientName         String
  stage              String
  number             String
  alternateNumber    String[]
  occupation         String?
  income             String?
  residence          String?
  location           String?
  interestedProperty String?
  propertyType       String?
  budget             String?
  visit              DateTime?
  createdAt          DateTime  @default(now())
  followUp           Json?
  notes              Json?
  propertyArea       String?
  userId             String?
  user               User?     @relation(fields: [userId], references: [id])
}
