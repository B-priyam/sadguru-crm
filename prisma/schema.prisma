generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id                 String    @id @default(uuid())
  clientName         String
  budget             String?
  createdAt          DateTime  @default(now())
  income             String?
  interestedProperty String?
  location           String?
  number             String
  occupation         String?
  propertyType       String?
  residence          String?
  stage              String
  updatedAt          DateTime?
  visit              DateTime?
  alternateNumber    String[]
  followUp           Json?
  notes              Json?
  propertyArea       String?
}

model Property {
  id        String   @id @default(uuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  units     Json
}

model RecentlyDeleted {
  id                 String    @id @default(uuid())
  clientName         String
  stage              String
  number             String
  alternateNumber    String[]
  occupation         String?
  income             String?
  residence          String?
  location           String?
  interestedProperty String?
  propertyType       String?
  budget             String?
  visit              DateTime?
  createdAt          DateTime  @default(now())
  followUp           Json?
  notes              Json?
  propertyArea       String?
}
